# Control-plane API + dashboard port
PORT=4000

# Edge reverse proxy ports (set EDGE_ENABLED=1 to run the proxy)
EDGE_ENABLED=0
EDGE_HTTP_PORT=8080
EDGE_HTTPS_PORT=8443

# Wildcard base domain. Apps deploy to <project>.<APP_DOMAIN>
APP_DOMAIN=krillin.local

# Publish an mDNS alias per live <app>.local host so apps resolve LAN-wide with
# no per-client /etc/hosts (Linux + avahi-utils only). MDNS_IP auto-detects.
MDNS_PUBLISH=0
MDNS_IP=

# JWT secret for dashboard sessions
SECRET=change-me-in-production

# The first account created via the dashboard becomes the admin. No bootstrap creds.

# SQLite control-plane database
DATABASE_PATH=./data/kettle.db

# Where source checkouts + build context live
WORKDIR=./workdir

# Host port range allocated to deployed containers
PORT_RANGE_START=20000
PORT_RANGE_END=20999

# ACME email for Let's Encrypt (production edge only)
ACME_EMAIL=

# Managed shared Postgres (apps attach a private database that gets a DATABASE_URL)
PG_IMAGE=postgres:16
PG_CONTAINER=kettle-postgres
PG_NETWORK=kettle-data
PG_VOLUME=kettle-pgdata
# 0 = don't publish a host port (apps use the docker network). Set e.g. 5440 to expose for external tools.
PG_HOST_PORT=0

# Report deploy status back to Tangle (git.local) as commit statuses. Both required.
# TANGLE_TOKEN is a Tangle personal access token (Settings → tokens) with repo write.
TANGLE_URL=
TANGLE_TOKEN=
# Public base URL of this Kettle, used for the status "Details" link (optional)
KETTLE_PUBLIC_URL=
